{
  "name": "remoteforge",
  "displayName": "RemoteForge",
  "description": "Delegate local developer tasks to remote VPS targets from VS Code and Cursor.",
  "publisher": "MichaelSam94",
  "version": "0.0.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/michaelsam94/RemoteForge.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:remoteforgeExplorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "remoteforge.openConfig",
        "title": "RemoteForge: Open Configuration"
      },
      {
        "command": "remoteforge.refreshExplorer",
        "title": "RemoteForge: Refresh Explorer"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:unit": "jest --runInBand",
    "package": "vsce package --allow-missing-repository",
    "audit": "npm audit --audit-level=high"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.32.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  }
}
